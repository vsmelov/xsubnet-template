# Скопируйте в .env и подставьте ключ (не коммитьте .env).
OPENAI_API_KEY=sk-proj-...

# Модель с vision
OPENAI_MODEL=gpt-4o-mini

# Сколько картинок максимум в одном запросе (vision + контекст)
FRAMES_PER_BATCH=6

# Стоимость для оценки USD (проверяйте на https://openai.com/api/pricing )
USD_PER_MTOK_INPUT=0.15
USD_PER_MTOK_OUTPUT=0.60
