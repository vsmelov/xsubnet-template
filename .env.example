NETUID=1
SUBTENSOR_CHAIN_ENDPOINT=ws://127.0.0.1:9944

MINER_WALLET_NAME=miner
MINER_WALLET_HOTKEY=default
MINER_AXON_PORT=8091

VALIDATOR_WALLET_NAME=validator
VALIDATOR_WALLET_HOTKEY=default
VALIDATOR_AXON_PORT=9101

OPENFLY_UNREALCV_PORT=9030
OPENFLY_DOCKER_UID=1000
OPENFLY_DOCKER_GID=1000

# Auto-bootstrap assets for validator stack.
OPENFLY_ASSET_AUTO_DOWNLOAD=1
OPENFLY_MODEL_REPO=IPEC-COMMUNITY/openfly-agent-7b
# If set, UE will be downloaded from this archive URL. If empty, HF dataset source is used.
OPENFLY_UE_ARCHIVE_URL=
OPENFLY_UE_DATASET_REPO=IPEC-COMMUNITY/OpenFly_DataGen
OPENFLY_UE_DATASET_SUBDIR=ue/env_ue_smallcity
# Optional private token for Hugging Face (required for gated assets)
HF_TOKEN=

# Miner: openai (default) = Chat Completions; openfly = HTTP VLM sidecar (see README).
OPENFLY_SUBNET_MINER_MODEL=openai
# When OPENFLY_SUBNET_MINER_MODEL=openfly — POST JSON body with instruction + optional context/frame.
OPENFLY_SUBNET_MINER_OPENFLY_URL=
# OPENFLY_SUBNET_MINER_OPENFLY_TIMEOUT=120

# When OPENFLY_SUBNET_MINER_MODEL=openai — OpenAI secret key (same value as in OpenAI dashboard “API keys”):
OPENAI_API_TOKEN=
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENFLY_SUBNET_MINER_OPENAI_MODEL=gpt-4o-mini

# Validator synthetic cadence is CLI-only (unless you wire flags into compose command):
#   --neuron.forward_sleep 3600   # seconds after each round (default 3600)
#   --neuron.timeout 10           # dendrite timeout per miner (seconds)
