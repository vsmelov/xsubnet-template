# Full stack: from xsubnet-template run `docker compose up -d --build` (see docker-compose.yml).
NETUID=1
SUBTENSOR_CHAIN_ENDPOINT=ws://127.0.0.1:9944

MINER_WALLET_NAME=miner
MINER_WALLET_HOTKEY=default
MINER_AXON_PORT=8091

VALIDATOR_WALLET_NAME=validator
VALIDATOR_WALLET_HOTKEY=default
VALIDATOR_AXON_PORT=9101

# Seconds between synthetic validator rounds (CLI: --neuron.forward_sleep). Default 1200 = 20 min; use 180 for 3 min tests.
OPENFLY_VALIDATOR_FORWARD_SLEEP=1200

# Random UE teleport list (same schema as main repo web/openfly_dashboard/teleport_spots.json).
OPENFLY_TELEPORT_SPOTS_JSON=/app/data/teleport_spots.json
# Seconds to wait after teleport before vget frame (drone settle).
OPENFLY_SYNTHETIC_POST_TELEPORT_SLEEP_SEC=2

# UnrealCV TCP port *inside* UE/validator stack (default 9030). Validator talks to 127.0.0.1:OPENFLY_UNREALCV_PORT.
OPENFLY_UNREALCV_PORT=9030
# Xvfb display number inside the UE container (default :99). Override if you collide with another local X server.
# OPENFLY_UE_XVFB_DISPLAY=:99

# Validator → miner HTTP: use host.docker.internal (see openfly-ue extra_hosts) when axon ip is 0.0.0.0 or equals
# dendrite.external_ip (bittensor maps that case to loopback 0.0.0.0, which breaks Docker + same public IP).
# OPENFLY_VALIDATOR_MINER_AXON_HOST=host.docker.internal
OPENFLY_DOCKER_UID=1000
OPENFLY_DOCKER_GID=1000

# Auto-bootstrap assets for validator stack.
OPENFLY_ASSET_AUTO_DOWNLOAD=1
OPENFLY_MODEL_REPO=IPEC-COMMUNITY/openfly-agent-7b
# If set, UE will be downloaded from this archive URL. If empty, HF dataset source is used.
OPENFLY_UE_ARCHIVE_URL=
OPENFLY_UE_DATASET_REPO=IPEC-COMMUNITY/OpenFly_DataGen
OPENFLY_UE_DATASET_SUBDIR=ue/env_ue_smallcity
# Optional private token for Hugging Face (required for gated assets)
HF_TOKEN=

# Miner: openai = Chat Completions; openfly = local HF VLM (CUDA miner image + ./models mount).
OPENFLY_SUBNET_MINER_MODEL=openai
# When MODEL=openfly — HF repo id or local path (compose default: /app/models/openfly-agent-7b).
OPENFLY_MODEL=/app/models/openfly-agent-7b
# OPENFLY_ATTN_IMPLEMENTATION=eager

# When OPENFLY_SUBNET_MINER_MODEL=openai — OpenAI secret key (same value as in OpenAI dashboard “API keys”):
OPENAI_API_TOKEN=
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENFLY_SUBNET_MINER_OPENAI_MODEL=gpt-4o-mini

# Validator synthetic cadence is CLI-only (unless you wire flags into compose command):
#   --neuron.forward_sleep 3600   # seconds after each round (default 3600)
#   --neuron.timeout 10           # dendrite timeout per miner (seconds)
